{%- liquid
  assign desktop_image = section.settings.desktop_image | default: section.settings.mobile_image
  assign mobile_image = section.settings.mobile_image | default: desktop_image
  assign image_alt = section.settings.alt_text | default: desktop_image.alt | default: shop.name | escape
-%}

{%- style -%}
  .custom-banner-location-c {
    margin-top: var(--custom-banner-location-c-margin-top, 0);
    margin-bottom: var(--custom-banner-location-c-margin-bottom, 0);
  }

  .custom-banner-location-c__inner {
    width: 100%;
  }

  .custom-banner-location-c--page .custom-banner-location-c__inner {
    max-width: var(--page-width, 120rem);
    margin-right: auto;
    margin-left: auto;
    padding-right: 1.5rem;
    padding-left: 1.5rem;
  }

  .custom-banner-location-c__link,
  .custom-banner-location-c__picture,
  .custom-banner-location-c__image {
    display: block;
  }

  .custom-banner-location-c__image,
  .custom-banner-location-c__placeholder-svg {
    width: 100%;
    height: auto;
  }

  .custom-banner-location-c__placeholder {
    background: rgb(var(--color-background, 255, 255, 255));
  }

  .custom-banner-location-c__placeholder-svg {
    min-height: 20rem;
  }

  @media screen and (min-width: 750px) {
    .custom-banner-location-c--page .custom-banner-location-c__inner {
      padding-right: 5rem;
      padding-left: 5rem;
    }
  }
{%- endstyle -%}

<section
  class="custom-banner-location-c custom-banner-location-c--{{ section.settings.width }}"
  style="--custom-banner-location-c-margin-top: {{ section.settings.margin_top }}px; --custom-banner-location-c-margin-bottom: {{ section.settings.margin_bottom }}px;"
>
  <div class="custom-banner-location-c__inner">
    {%- if desktop_image != blank -%}
      {%- capture banner_media -%}
        <picture class="custom-banner-location-c__picture">
          {%- if section.settings.mobile_image != blank -%}
            <source
              media="(max-width: 749px)"
              srcset="
                {{ mobile_image | image_url: width: 375 }} 375w,
                {{ mobile_image | image_url: width: 550 }} 550w,
                {{ mobile_image | image_url: width: 750 }} 750w,
                {{ mobile_image | image_url: width: 1100 }} 1100w
              "
              sizes="100vw"
            >
          {%- endif -%}
          {{
            desktop_image
            | image_url: width: 2400
            | image_tag:
              class: 'custom-banner-location-c__image',
              loading: 'lazy',
              widths: '750, 1100, 1500, 1780, 2000, 2400',
              sizes: '100vw',
              alt: image_alt
          }}
        </picture>
      {%- endcapture -%}

      {%- if section.settings.banner_link != blank -%}
        <a class="custom-banner-location-c__link" href="{{ section.settings.banner_link }}" aria-label="{{ image_alt }}">
          {{ banner_media }}
        </a>
      {%- else -%}
        {{ banner_media }}
      {%- endif -%}
    {%- else -%}
      <div class="custom-banner-location-c__placeholder">
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg custom-banner-location-c__placeholder-svg' }}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Custom banner location C",
  "tag": "section",
  "class": "section-custom-banner-location-c",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop banner image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile banner image"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner link"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Image alt text",
      "default": "Store banner"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Banner width",
      "default": "full",
      "options": [
        {
          "value": "full",
          "label": "Full width"
        },
        {
          "value": "page",
          "label": "Page width"
        }
      ]
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top spacing",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Custom banner location C"
    }
  ]
}
{% endschema %}
