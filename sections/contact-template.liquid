{% comment %}
  The contents of the page.contact.liquid template can be found in /sections/contact-template.liquid
{% endcomment %}

{% comment %}
  ** Contact page - custom view **
  - Page template
{% endcomment %}
{% if section.settings.image != null %}
  <header class="banner center page_banner dark-overlay-{{ section.settings.image_darken }}">
    <img
      src="{{ section.settings.image | img_url: '100x' }}"
      alt="{% if section.settings.image.alt != blank %}{{ section.settings.image.alt | escape }}{% else %}{{ page.title | escape }}{% endif %}"
      class="lazyload {{ settings.image_loading_style }}"
      data-src="{{ section.settings.image | img_url: '1400x', format: 'pjpg' }}"
      sizes="100vw"
      height="auto" width="auto"
      srcset="{{ section.settings.image | img_url: '480x', format: 'pjpg' }} 480w, {{ section.settings.image | img_url: '765x', format: 'pjpg' }} 765w, {{ section.settings.image | img_url: '1400x', format: 'pjpg' }} 1400w, {{ section.settings.image | img_url: '2048x', format: 'pjpg' }} 2048w"
    >
    <div class="caption captionOverlay--true">
      <h1 class="headline">{{ section.settings.title }}</h1>
      <p class="subtitle">{{ section.settings.subtitle }}</p>
    </div>
  </header>
{% endif %}
<a name="pagecontent" id="pagecontent"></a>
<div class="container main content main-container">
    <div class="contact-page-content">
        <div class="page-title">
            {% if section.settings.image == null %}
            <h1>{{ page.title }}</h1>
            {% endif %}
        </div>
        <div class="contact-page-inner">
            <div class="row">
                <div class="contact-page-coustmer wi-25 wi-100">
                    <div class="contact-page-box-title">
                        <h4 class="page-c-heading">CUSTOMER CARE</h4>
                    </div>
                    <div class="contact-page-box-content">
                        <div class="contact-menu-list">
                            <ul>
                                {% for link in linklists['contact-us'].links %}
                                <li>
                                    <a href="{{ link.url }}">{{ link.title }}</a>
                                </li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="contact-support-box wi-50 wi-100">
                    <div class="contact-page-box-content">
                        <div class="contact-support-intro">
                            <p class="contact-support-eyebrow page-c-heading">{{ section.settings.support_eyebrow | default: "WE'RE HERE TO HELP" }}</p>
                            <h2 class="contact-support-title page-c-heading">{{ section.settings.title | default: "Reach Us" }}</h2>
                            <div class="contact-support-text page-c-desc">
                                {% if section.settings.text != blank %}
                                    {{ section.settings.text }}
                                {% else %}
                                    <p>Questions about an order, sizing, or anything else? Our team would love to help.</p>
                                {% endif %}
                            </div>
                        </div>

                        <div class="contact-support-methods">
                            <div class="contact-support-content">
                                <div class="contact-support-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" focusable="false">
                                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.35 1.94.7 2.89a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.18-1.27a2 2 0 0 1 2.11-.45c.95.35 1.93.57 2.89.7A2 2 0 0 1 22 16.92z"></path>
                                    </svg>
                                </div>
                                <h3 class="page-c-heading">{{ section.settings.phone_title | default: "BY PHONE" }}</h3>
                                <a class="page-c-desc contact-support-primary" href="tel:{{section.settings.phone_number}}">{{ section.settings.phone_number | default: "[CS PHONE]" }}</a>
                                <div class="page-c-desc contact-support-note">{{ section.settings.phone_note | default: "Monday-Friday<br>9:00 AM - 5:00 PM CT" }}</div>
                            </div>
                            <div class="contact-support-content">
                                <div class="contact-support-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" focusable="false">
                                        <path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"></path>
                                        <path d="m22 7-10 7L2 7"></path>
                                    </svg>
                                </div>
                                <h3 class="page-c-heading">{{ section.settings.email_title | default: "BY EMAIL" }}</h3>
                                <a class="page-c-desc contact-support-primary" href="mailto:{{section.settings.contactemail}}">{{ section.settings.contactemail}}</a>
                                <div class="page-c-desc contact-support-note">{{ section.settings.email_note | default: "We reply within 1-2 business days" }}</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="contact-locations-grid">
                        {% for block in section.blocks %}
                          {% if block.type == 'location' %}
                          <div class="contact-location">
                              {% if block.settings.ofc_title != blank %}
                              <h4 class="contact-location__title page-c-heading">
                                  {{ block.settings.ofc_title }}
                              </h4>
                              {% endif %}

                              {% if block.settings.ofc_html != blank %}
                              <p class="contact-location__details page-c-desc">
                                  {{ block.settings.ofc_html }}
                              </p>
                              {% endif %}
                              {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                                  <a href="{{ block.settings.button_link }}" class="view-store-btn">{{ block.settings.button_label }}</a>
                                {% endif %}
                          </div>
                          {% endif %}
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<style>
  .contact-page-content h1 {
    font-size:30px;
    font-weight: 400;
    letter-spacing:0.5px;
    
  }

  .contact-page-content {
    margin-bottom: 100px;
  }

  .contact-page-content .page-c-heading {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin:0;

    padding: 0;
  }

  .contact-page-content .page-c-desc {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.5px;
    
    margin: 0;
  }

  .contact-page-coustmer .contact-page-box-content .contact-menu-list ul li a {
    font-size: 16px;
    letter-spacing: 0px;
    
  }

  .contact-locations-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    justify-content: space-between;
    gap: 20px;
  }

  .contact-page-content .contact-support-box.wi-50.wi-100 {
    width: 75%;
    padding:0;
  }

  .contact-locations-grid .contact-location{
    box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.07);
    padding: 30px 20px;
    border-radius: 10px;
    text-align: center;
  }

  .contact-locations-grid h4 {
    min-height:70px;
  }

  .contact-locations-grid span {
    min-height:69px;
    display:block;
  }

  .contact-locations-grid span, b {
    line-height:20px;
  }

  .contact-locations-grid b {
    font-weight:600;
    margin:15px 0;
    display:block;
  }

  .contact-support-box > .contact-page-box-content {
    margin-bottom: 40px !important;
    padding: 54px 32px 48px;
    text-align: center;
    background: linear-gradient(180deg, #fff1f8 0%, #fff 82%);
  }

  .contact-support-intro {
    margin: 0 auto 30px;
  }

  .contact-support-eyebrow {
    margin: 0 0 18px;
    color: #d83d8d;
    letter-spacing: 6px;
    line-height: 1.2;
    font-size: 13px !important;
  }

  .contact-support-title {
    margin:20px 0 !important;
    color: #1f1f23;
    font-size: 28px !important;
    letter-spacing: 1px;
    line-height: 1.1;
    font-weight: 400 !important;
  }

  .contact-support-text {
    color: #747474;
    line-height: 1.5;
  }

  .contact-support-text p {
    margin: 0;
  }

  .contact-support-methods {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    align-items: stretch;
  }

  .contact-support-content {
    margin-bottom: 0 !important;
    padding: 0 34px;
    text-align: center;
  }

  .contact-support-content + .contact-support-content {
    border-left: 1px solid #dedede;
  }

  .contact-support-icon {
    width: 50px;
    height: 50px;
    margin: 0 auto 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #eadfe5;
    border-radius: 50%;
    background: #fff;
  }

  .contact-support-icon svg {
    width: 25px;
    height: 25px;
    fill: none;
    stroke: #d83d8d;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .contact-support-content .page-c-heading {
    margin-bottom: 18px;
    color: #777;
  }

  .contact-support-primary {
    display: block;
    margin-bottom: 18px !important;
    color: #202026 !important;
    font-weight: 600 !important;
    letter-spacing: 0 !important;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .contact-support-note {
    color: #777;
    line-height: 1.5;
  }

  .contact-support-content p a {
    line-height:normal;
  }

  .contact-page-box-content {
    padding-top: 0;
    margin-top: 0;
  }

  .contact-support-box > .contact-page-box-content {
    padding-top: 54px;
  }

  .contact-page-content .contact-page-box-title {
    margin-bottom: 24px;
  }

  .contact-page-coustmer .contact-page-box-content .contact-menu-list ul li {
    margin-bottom:18px;
  }

  .contact-page-content {
    margin-bottom: 50px;
  }
  .view-store-btn {
  display: inline-block;
  margin-top: 15px;
  padding: 4px 30px;
  color: #fff;
  text-decoration: none;
  font-size: 11px;
  border: solid 1px transparent;
  background: #000;
  text-transform: uppercase;
}
.view-store-btn:hover,
.view-store-btn:focus,
.view-store-btn:active {
  background: none;
  border: solid 1px #000;
  color: #000 !important;
}
.view-store-btn:visited {
    color: #fff !important;
}
.view-store-btn:hover {
    color: #000 !important;
}
.contact-page-coustmer {
    padding: 0 !important;
}

@media (max-width: 1024px) {
  .contact-location-row {
    grid-template-columns: 1fr 1fr;
  }

  .contact-page-content .page-c-heading {
    font-size: 12px;
  }

  .contact-locations-grid h4 {
    min-height: 50px;
  }

  .contact-page-content .page-c-desc {
    font-size: 10px;
  }

  .contact-locations-grid span, b {
    line-height: 15px;
  }

  .contact-locations-grid b {
    margin: 10px 0;
  }

  .contact-locations-grid span {
    min-height: 49px;
  }

  .contact-page-coustmer .contact-page-box-content .contact-menu-list ul li a {
    font-size: 10px;
  }

  .contact-page-content h1 {
    font-size: 20px;
    margin: 0 0 20px;
  }

  .contact-support-box > .contact-page-box-content {
    padding: 42px 20px 36px;
    padding-top: 42px;
  }

  .contact-support-intro {
    margin-bottom: 50px;
  }

  .contact-support-eyebrow {
    letter-spacing: 4px;
  }

  .contact-support-title {
    font-size: 30px;
    margin-bottom: 22px;
  }

  .contact-support-content {
    padding: 0 22px;
  }

  .contact-support-icon {
    margin-bottom: 20px;
  }


  .contact-support-content .page-c-heading {
    letter-spacing: 3px;
  }

}

@media (max-width: 800px) {
  .contact-location-row {
    grid-template-columns: 1fr 1fr;
  }

  .contact-locations-grid {
    grid-template-columns: repeat(1, 1fr);
  }

  .contact-page-content .contact-support-box.wi-50.wi-100 {
    width: 100%;
  }

  .contact-locations-grid b {
    margin:15px 0;
  }

  .contact-locations-grid span {
      min-height: auto;
  }

  .contact-locations-grid h4 {
      min-height: auto;
      margin-bottom: 10px !important;
  }

  .contact-page-content {
      margin-bottom: 30px;
  }

  .contact-page-content .wi-100 {
    width: 100%;
    padding: 0;
  }

  .contact-page-content .contact-page-box-title {
    margin-bottom: 10px;
  }

  .contact-page-coustmer .contact-page-box-content .contact-menu-list ul li {
    margin-bottom: 6px;
  }

  .contact-support-box > .contact-page-box-content {
    padding: 36px 18px 32px;
    padding-top: 36px;
  }

  .contact-support-intro {
    margin-bottom: 40px;
  }

  .contact-support-title {
    font-size: 28px;
  }

  .contact-support-methods {
    grid-template-columns: 1fr;
    gap: 26px;
  }

  .contact-support-content {
    padding: 0;
  }

  .contact-support-content + .contact-support-content {
    padding-top: 26px;
    border-left: 0;
    border-top: 1px solid #dedede;
  }
}

</style>

{% schema %}
{
  "name": "Contact",
  "class": "contact-section",
  "settings": [
	 {
        "type": "text",
        "id": "title",
        "label": "Support Heading",
        "default": "Reach Us"
     },
     {
        "type": "text",
        "id": "support_eyebrow",
        "label": "Support Eyebrow",
        "default": "WE'RE HERE TO HELP"
     },
	 {
        "type": "richtext",
        "id": "text",
        "label": "Text",
        "default": "<p>Questions about an order, sizing, or anything else? Our team would love to help.</p>"
     },
 	 {
        "type": "text",
        "id": "hour_title",
        "label": "Hour Title"
     },
     {
       "type": "html",
       "id": "hour_html",
       "label": "Hour HTML"
     },

     {
          "type": "text",
          "id": "main_ofc_title",
          "label": "Main Office Title"
        },
        {
          "type": "html",
          "id": "main_ofc_html",
          "label": "Main Office HTML"
        },
	 
	 {
        "type": "text",
        "id": "phone_title",
        "label": "Phone Heading",
        "default": "BY PHONE"
     },
	 {
        "type": "text",
        "id": "phone_number",
        "label": "Phone Number",
        "default": "[CS PHONE]"
     },
     {
        "type": "html",
        "id": "phone_note",
        "label": "Phone Note",
        "default": "Monday-Friday<br>9:00 AM - 5:00 PM CT"
     },
	 {
        "type": "text",
        "id": "email_title",
        "label": "Email Heading",
        "default": "BY EMAIL"
     },
	 {
        "type": "text",
        "id": "contactemail",
        "label": "Email"
     },
     {
        "type": "html",
        "id": "email_note",
        "label": "Email Note",
        "default": "We reply within 1-2 business days"
     },
	 {
        "type": "text",
        "id": "contact_heading",
        "label": "Contact Form Heading"
     },
	 {
        "type": "richtext",
        "id": "contact_subtitle",
        "label": "Contact Form Sub title"
     },
 	 {
        "type": "text",
        "id": "contact_bug_heading",
        "label": "Contact Bug Form Heading"
     },
	 {
        "type": "richtext",
        "id": "contact_bug_subtitle",
        "label": "Contact Bug Form Sub title"
     },
    {
      "type": "text",
      "id": "contact_style_expert_label",
      "label": "Contact Expert Label"
     },
 	 {
        "type": "url",
        "id": "contact_style_expert_link",
        "label": "Contact Expert link"
     },
 	 {
        "type": "image_picker",
        "id": "contactexpertimage",
        "label": "Contact Expert Image"
     }
  ],

  "blocks": [
    {
      "type": "location",
      "name": "Location Block",
      "settings": [
        {
          "type": "text",
          "id": "ofc_title",
          "label": "Title"
        },
        {
          "type": "html",
          "id": "ofc_html",
          "label": "Main Office HTML"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },

      ]
    },
  ]
}
{% endschema %}
