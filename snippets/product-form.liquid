{% assign variant = product.selected_or_first_available_variant %}
{% comment %} Hide native cart UI for patch-app products, UNLESS they carry the show-add-to-cart tag {% endcomment %}
{% assign hide_for_patch_app = false %}
{% if product.tags contains 'patch-app-category' %}
  {% assign hide_for_patch_app = true %}
  {% if product.tags contains 'show-add-to-cart' %}
    {% assign hide_for_patch_app = false %}
  {% endif %}
{% endif %}
{% assign selected_variant_should_hide = false %}
{% if variant.metafields.custom.hide_when_out_of_stock.value == true or variant.metafields.custom.hide_when_out_of_stock.value == 'true' or variant.metafields.custom.hide_when_out_of_stock.value == 'True' %}
  {% if variant.available == false %}
    {% assign selected_variant_should_hide = true %}
  {% endif %}
{% endif %}
{% if selected_variant_should_hide %}
  {% for variant_check in product.variants %}
    {% assign variant_check_should_hide = false %}
    {% if variant_check.metafields.custom.hide_when_out_of_stock.value == true or variant_check.metafields.custom.hide_when_out_of_stock.value == 'true' or variant_check.metafields.custom.hide_when_out_of_stock.value == 'True' %}
      {% if variant_check.available == false %}
        {% assign variant_check_should_hide = true %}
      {% endif %}
    {% endif %}
    {% unless variant_check_should_hide %}
      {% assign variant = variant_check %}
      {% break %}
    {% endunless %}
  {% endfor %}
{% endif %}

<form
  action="/cart/add"
  method="post"
  class="clearfix product_form init is-visible {% if product.variants.size > 1 or product.options.size > 1 %}product_form_options{% endif %}"
  id="product-form-{{ product.id }}"
  data-money-format="{{ shop.money_format }}"
  data-shop-currency="{{ shop.currency }}"
  data-select-id="product-select-{{ product.id }}{{ product-form }}{{ section.id }}{{ block.id }}"
  data-enable-state="{% if template contains 'product' %}true{% else %}false{% endif %}"
  data-product="{% include 'wh_product_json' with product, escape: true %}"
  {% if settings.limit_quantity or settings.display_inventory_left %}
    data-variant-inventory="[{%- for v in product.variants -%}{"id":{{v.id}},"inventory_quantity":{{v.inventory_quantity}},"inventory_management":"{{v.inventory_management}}","inventory_policy":"{{v.inventory_policy}}"}{% if forloop.last == false %},{% endif %}{%- endfor -%}]"
  {% endif %}
  data-product-id="{{ product.id }}"
>
  <div class="bold_options" data-product-id="{{ product.id }}"></div>

  {% if product.options.size > 1 %}
    <div class="select">
      <select
        id="product-select-{{ product.id }}{{ product-form }}{{ section.id }}{{ block.id }}"
        name="id"
        class="multi_select"
      >
        {% for v in product.variants %}
          {% assign hide_variant_option = false %}
          {% if v.metafields.custom.hide_when_out_of_stock.value == true or v.metafields.custom.hide_when_out_of_stock.value == 'true' or v.metafields.custom.hide_when_out_of_stock.value == 'True' %}
            {% if v.available == false %}
              {% assign hide_variant_option = true %}
            {% endif %}
          {% endif %}
          {% unless hide_variant_option %}
            <option
              {% if v == variant %}
                selected="selected"
              {% endif %}
              value="{{ v.id }}"
              data-sku="{{ v.sku }}"
            >
              {{ v.title }}
            </option>
          {% endunless %}
        {% endfor %}
      </select>
    </div>
  {% elsif product.options.size == 1
    and product.variants.size > 1
    or product.options.size == 1
    and product.options[0] != 'Title'
  %}
    <div class="select">
      <label>{{ product.options[0] }}</label>
      <select id="product-select-{{ product.id }}{{ product-form }}{{ section.id }}{{ block.id }}" name="id">
        {% for v in product.variants %}
          {% assign hide_variant_option = false %}
          {% if v.metafields.custom.hide_when_out_of_stock.value == true or v.metafields.custom.hide_when_out_of_stock.value == 'true' or v.metafields.custom.hide_when_out_of_stock.value == 'True' %}
            {% if v.available == false %}
              {% assign hide_variant_option = true %}
            {% endif %}
          {% endif %}
          {% unless hide_variant_option %}
            <option
              {% if v == variant %}
                selected="selected"
              {% endif %}
              value="{{ v.id }}"
              data-sku="{{ v.sku }}"
            >
              {{ v.title }}
            </option>
          {% endunless %}
        {% endfor %}
      </select>
    </div>
  {% else %}
    <input type="hidden" name="id" value="{{ variant.id }}">
  {% endif %}

  {% if settings.product_form_style == 'swatches'
    and product.variants.size > 1
    or settings.product_form_style == 'swatches'
    and product.options[0] != 'Title'
  %}
    <div class="swatch_options {% if product.tags contains "patch-options-hide" %} patch-options-hide{% endif %}">
      {% for option in product.options %}
        {% include 'product-swatch' with option %}
      {% endfor %}
    </div>
  {% endif %}
  {% if settings.display_inventory_left %}
    <div class="items_left">
      {% if variant.inventory_management != blank and variant.inventory_quantity > 0 %}
        {% capture items_left_text %}
            {% if variant.inventory_quantity == 1 %}
              {{ 'products.product.items_left_count.one' | t }}
            {% else %}
              {{ 'products.product.items_left_count.other' | t }}
            {% endif %}
          {% endcapture %}

        <p>
          <em>
            {{- variant.inventory_quantity }}
            {{ items_left_text -}}
          </em>
        </p>
      {% endif %}
    </div>
  {% endif %}
  {% if product.available %}
    {% if settings.display_product_quantity %}
      <div class="gPositionLimitMessage"></div>

      {% unless hide_for_patch_app %}
        {% unless product.tags contains 'quanity-hide' %}
          <div class="left product-quantity-box">
            <label for="quantity">{{ 'products.product.quantity' | t }}</label>
            <span class="ss-icon product-minus js-change-quantity" data-func="minus"
              ><span class="icon-minus"></span
            ></span>
            <input
              type="number"
              min="1"
              size="2"
              class="quantity"
              name="quantity"
              data-id="{{product.id}}"
              id="quantity"
              value="1"
              {% if settings.limit_quantity
                and variant.inventory_management != blank
                and variant.inventory_policy == 'deny'
              %}
                max="{{ variant.inventory_quantity }}"
              {% endif %}
            >
            <span class="ss-icon product-plus js-change-quantity" data-func="plus"
              ><span class="icon-plus"></span
            ></span>
          </div>
        {% endunless %}
      {% endunless %}
    {% endif %}

    <div class="purchase clearfix {% if settings.display_product_quantity %}inline_purchase{% endif %}">
      {% if wh_settings_cart_action == 'reload_page' %}
        <input type="hidden" name="return_to" value="back">
      {% elsif wh_settings_cart_action == 'redirect_checkout' %}
        <input type="hidden" name="return_to" value="/checkout">
      {% endif %}

      {% capture add_to_cart_label %}{% if collection_handles contains 'pre-order' %}{{ 'collections.general.pre_order' | t }}{% else %}{{ 'products.product.add_to_cart' | t }}{% endif %}{% endcapture %}

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
        {% endcase %}
      {% endfor %}

      {% unless hide_for_patch_app %}
        {% if product.tags contains 'name-field' %}
          <div class="workshop custom-variants">
            {% render 'workshop-variants' %}
          </div>
        {% endif %}
        <div class="product_cart_btns">
          <button
            type="submit"
            name="add"
            class="action_button add_to_cart liquid_ajax_cart {% if collection.handle contains 'look-book' %}lookbook_lookbook_btn{% endif %}"
            data-label="Add to Bag"
          >
            <span class="text">{{ add_to_cart_label }}</span>
            <svg x="0px" y="0px" width="32px" height="32px" viewBox="0 0 32 32" class="checkmark">
              <path fill="none" stroke="{{ settings.btn_text_color }}" stroke-width="2" stroke-linecap="square" stroke-miterlimit="10" d="M9,17l3.9,3.9c0.1,0.1,0.2,0.1,0.3,0L23,11"/>
            </svg>
          </button>
          <button
            type="submit"
            name="add"
            class=" checkout_btn_product"
            data-label="Add to Bag"
            onclick="checkoutdirect()"
          >
            <script>
              function checkoutdirect() {
                setTimeout(function () {
                  window.location.href = '/checkout';
                }, 1500);
              }
            </script>
            <span>BUY NOW</span>
            <svg x="0px" y="0px" width="32px" height="32px" viewBox="0 0 32 32" class="checkmark">
              <path fill="none" stroke="{{ settings.btn_text_color }}" stroke-width="2" stroke-linecap="square" stroke-miterlimit="10" d="M9,17l3.9,3.9c0.1,0.1,0.2,0.1,0.3,0L23,11"/>
            </svg>
          </button>
        </div>
      {% endunless %}
      {% comment %}
        <p class="action_button btn add-cart" onclick="addItem('product-form-{{ product.id }}'); return false;" data-cart-add="{{ product.id }}">Add to Cart</p>
      {% endcomment %}

      <template id="giftnote-pdp">
        <style>
          #container{
            margin-bottom: 20px;
          }
          #button{
            border-radius: 0;
            border-width: 2px;
            text-transform: uppercase;
            font-weight: 700;
            font-size:14px;
          }
        </style>
      </template>
      {% if product.vendor == 'Giftnote' %}
        <giftnote-voucher-button
          data-styles="giftnote-pdp"
          data-label="Send as a gift 🎁"
        ></giftnote-voucher-button>
      {% else %}
        <!--
          <giftnote-button
            data-styles="giftnote-pdp"
            data-add="Add a gift message 🎁"
            data-edit="Edit gift message 🎁"
          ></giftnote-button>
        -->
      {% endif %}
    </div>
  {% endif %}

  <!-- wishlist app integration -->
  {% comment %}
    {% include 'iwish_v2' with 'iwishproduct' %}
  {% endcomment %}
  <span class="success_added_item" style="display:none;">Item Successfully added in cart!</span>
  <div class="varinat-error" data-ajax-cart-messages="form">
    <!-- Errors and messages appear here -->
  </div>
</form>

<script>
  $(document).ready(function () {
    var productForm = $('#product-form-{{ product.id }}');
    var metaControlledVariants = [
      {% for v in product.variants %}
        {
          option1: {{ v.option1 | json }},
          option2: {{ v.option2 | json }},
          option3: {{ v.option3 | json }},
          available: {{ v.available | json }},
          inventory_quantity: {{ v.inventory_quantity | json }},
          inventory_management: {{ v.inventory_management | json }},
          hide_meta: {{ v.metafields.custom.hide_when_out_of_stock.value | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];
    var isApplyingMetaHide = false;

    function metaValueIsTrue(value) {
      return value === true || value === 'true' || value === 'True';
    }

    function shouldHideByMeta(variantData) {
      if (!metaValueIsTrue(variantData.hide_meta)) return false;
      if (variantData.available === false) return true;
      return false;
    }

    function getSelectedOptionValues($form) {
      var selected = [];
      $form.find('.single-option-selector').each(function () {
        selected.push($(this).val() || '');
      });
      if (!selected.length) {
        $form.find('.swatch').each(function () {
          selected.push($(this).find('input:checked').val() || '');
        });
      }
      return selected;
    }

    function matchingVariantsForValue(value, optionIndex, selectedValues) {
      return metaControlledVariants.filter(function (variantData) {
        var options = [variantData.option1 || '', variantData.option2 || '', variantData.option3 || ''];
        if (options[optionIndex] !== value) return false;
        for (var index = 0; index < optionIndex; index += 1) {
          if (!selectedValues[index]) continue;
          if (options[index] !== selectedValues[index]) return false;
        }
        return true;
      });
    }

    function applyMetafieldVariantHiding($form) {
      if (isApplyingMetaHide || !$form.length) return;
      isApplyingMetaHide = true;

      var selectedValues = getSelectedOptionValues($form);

      $form.find('.swatch').each(function () {
        var $swatchGroup = $(this);
        var optionIndex = Number($swatchGroup.attr('data-option-index'));
        if (isNaN(optionIndex)) return;

        $swatchGroup.find('.swatch-element').each(function () {
          var $swatchElement = $(this);
          var value = $swatchElement.attr('data-value');
          var matches = matchingVariantsForValue(value, optionIndex, selectedValues);
          if (!matches.length) return;

          var hasVisibleMatch = matches.some(function (variantData) {
            return !shouldHideByMeta(variantData);
          });
          var $radioInput = $swatchElement.prev('input[type="radio"]');

          if (hasVisibleMatch) {
            $swatchElement.show();
            $radioInput.prop('disabled', false);
          } else {
            $swatchElement.hide();
            $radioInput.prop('checked', false).prop('disabled', true);
          }
        });

        var $selectedVisible = $swatchGroup.find('input[type="radio"]:checked').filter(function () {
          return $(this).next('.swatch-element').is(':visible');
        });

        if (!$selectedVisible.length) {
          var $firstVisible = $swatchGroup.find('.swatch-element:visible').first().prev('input[type="radio"]');

          if ($firstVisible.length) {
            $firstVisible.prop('checked', true).trigger('change');
          }
        }
      });

      isApplyingMetaHide = false;
    }

    if (productForm.length) {
      setTimeout(function () {
        applyMetafieldVariantHiding(productForm);
      }, 0);

      productForm.on('change', '.swatch :radio, .single-option-selector', function () {
        setTimeout(function () {
          applyMetafieldVariantHiding(productForm);
        }, 0);
      });
    }

    $('.swatch-element').on('click', function () {
      if ($(this).hasClass('soldout')) {
        $('.checkout_btn_product')[0].style.display = 'none';
      } else {
        $('.checkout_btn_product')[0].style.display = 'block';
      }
    });
    const addToCartButton = document.querySelector('.action_button.add_to_cart.liquid_ajax_cart');
    const checkoutButton = document.querySelector('.checkout_btn_product');

    if (addToCartButton && checkoutButton) {
      // Function to toggle class on the checkout button
      const toggleCheckoutButtonClass = () => {
        if (addToCartButton.classList.contains('disabled')) {
          checkoutButton.classList.add('hide-checkout-btn');
        } else {
          checkoutButton.classList.remove('hide-checkout-btn');
        }
      };
      toggleCheckoutButtonClass();

      // Observe changes to the 'Add to Cart' button's class and toggle accordingly
      const observer = new MutationObserver(toggleCheckoutButtonClass);
      observer.observe(addToCartButton, { attributes: true, attributeFilter: ['class'] });
    }
  });
</script>
