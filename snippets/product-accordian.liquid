{{ 'custom-product-accordian.css' | asset_url | stylesheet_tag }}

{%- assign hide_size_chart = false -%}
{%- if product.tags contains 'Shoes'
    or product.tags contains 'sneakers'
    or product.tags contains 'Slippers'
    or product.tags contains 'slides'
    or product.tags contains 'loafers' -%}
  {%- assign hide_size_chart = true -%}
{%- endif -%}

<section class="ProductTabs" id="ProductTabs-{{ product.id }}">
  <div class="ProductTabs__nav" role="tablist">
    {% if product.description != blank %}
      <button type="button" class="ProductTabs__navItem active" data-tab="details-{{ product.id }}" role="tab">Details</button>
    {% endif %}

    <button type="button" class="ProductTabs__navItem" data-tab="shipping-{{ product.id }}" role="tab">Shipping &amp; Returns</button>

    <button type="button" class="ProductTabs__navItem" data-tab="fitsize-{{ product.id }}" role="tab">Fit &amp; Size</button>
  </div>

  <div class="ProductTabs__panels">
    {% if product.description != blank %}
      <div class="ProductTabs__panel active" id="details-{{ product.id }}" role="tabpanel">
        {{ product.description }}
      </div>
    {% endif %}

    <div class="ProductTabs__panel" id="shipping-{{ product.id }}" role="tabpanel">
      {%- assign is_final_sale = false -%}
      {%- if product.tags contains 'saleonsale'
          or product.tags contains 'Sale'
          or product.tags contains 'FINALSALE50' -%}
        {%- assign is_final_sale = true -%}
      {%- endif -%}

      <ul>
        <li>Fast shipping from Chicago</li>

        {% if product.tags contains 'patch-app-category' %}
          <li>Customized and personalized items are final sale and cannot be returned or exchanged.</li>
        {% elsif is_final_sale %}
          <li>Item is Final Sale &mdash; no returns or exchanges</li>
        {% else %}
          <li>21 - day return policy for a refund or exchange.</li>
        {% endif %}

        <li>Free shipping on orders $250+.</li>
      </ul>
    </div>

    <div class="ProductTabs__panel" id="fitsize-{{ product.id }}" role="tabpanel">
      <ul class="ProductTabs__fitsizeIntro">
        <li>Our kids&rsquo; sizes run from 2 to 14 (size 4 fits a 4-year-old, size 8 fits an 8-year-old).</li>
        <li>Women&rsquo;s styles run Small &ndash; Extra Large.</li>
      </ul>

      {% unless hide_size_chart %}
        <div class="ProductTabs__sizeChart">
          {% render 'size-chart-popup' %}
        </div>
      {% endunless %}

      {% if product.metafields.custom.overallfit or product.metafields.custom.model_wear %}
        <div class="ProductTabs__truetosize">
          {% render 'product-overallfit' %}
        </div>
      {% endif %}
    </div>
  </div>
</section>


<script>
  (function () {
    var container = document.getElementById('ProductTabs-{{ product.id }}');
    if (!container) return;
    var tabs = container.querySelectorAll('.ProductTabs__navItem');
    var panels = container.querySelectorAll('.ProductTabs__panel');

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        var target = tab.getAttribute('data-tab');
        tabs.forEach(function (t) { t.classList.remove('active'); });
        panels.forEach(function (p) { p.classList.remove('active'); });
        tab.classList.add('active');
        var panel = container.querySelector('#' + target);
        if (panel) panel.classList.add('active');
      });
    });
  })();
</script>
